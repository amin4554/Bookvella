// Bookvella database schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LocationType {
  VIDEO
  PHONE
  IN_PERSON
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

enum PriceType {
  FIXED
  FROM
  RANGE
  FREE
}

enum AvailabilityOverrideType {
  BLOCKED
  CUSTOM_HOURS
}

enum EventTypeAvailabilityMode {
  HOST_DEFAULT
  CUSTOM
}

enum NotificationChannel {
  EMAIL
  SMS
}

enum NotificationType {
  NEW_BOOKING
  CANCELLATION
  DAILY_AGENDA
  REMINDER_BEFORE
  PRODUCT_UPDATES
}

enum BookingReminderStatus {
  PENDING
  PROCESSING
  SENT
  CANCELLED
  FAILED
}

enum DailyAgendaStatus {
  PROCESSING
  SENT
  FAILED
}

enum CalendarProvider {
  GOOGLE
  OUTLOOK
}

enum ConnectedCalendarState {
  ACTIVE
  PAUSED
  SYNC_ERROR
  TOKEN_EXPIRED
}

enum CalendarEventSyncStatus {
  PENDING
  SYNCED
  FAILED
  DELETED
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String   @map("password_hash")
  passwordSetAt    DateTime? @map("password_set_at")
  googleSub        String?  @unique @map("google_sub")
  totpSecret       String?  @map("totp_secret")
  totpEnabledAt    DateTime? @map("totp_enabled_at")
  name             String
  businessDisplayName String? @map("business_display_name")
  slug             String   @unique
  timezone         String   @default("UTC")
  profileImageUrl  String?  @map("profile_image_url")
  coverImageUrl    String?  @map("cover_image_url")
  headline         String?
  businessCategory String?  @map("business_category")
  location         String?
  about            String?
  whatToExpect     String?  @map("what_to_expect")
  websiteUrl       String?  @map("website_url")
  instagramUrl     String?  @map("instagram_url")
  minNoticeMinutes    Int     @default(120) @map("min_notice_minutes")
  bookingHorizonDays  Int     @default(56)  @map("booking_horizon_days")
  slotIntervalMinutes Int     @default(15)  @map("slot_interval_minutes")
  dailyBookingLimit   Int?    @map("daily_booking_limit")
  showBufferTime      Boolean @default(false) @map("show_buffer_time")
  isActive            Boolean @default(true) @map("is_active")
  deactivatedAt       DateTime? @map("deactivated_at")
  isProfileHidden     Boolean @default(false) @map("is_profile_hidden")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  sessions               UserSession[]
  passwordResetTokens    PasswordResetToken[]
  accountEmailChanges    AccountEmailChange[]
  backupCodes            UserBackupCode[]
  notificationPreferences NotificationPreference[]
  eventTypes             EventType[]
  availabilityRules      AvailabilityRule[]
  availabilityOverrides  AvailabilityOverride[]
  availabilitySchedules  AvailabilitySchedule[]
  bookings               Booking[]
  reviews                Review[]
  dailyAgendaDeliveries  DailyAgendaDelivery[]
  connectedCalendars     ConnectedCalendar[]
  bookingFeed            BookingFeed?
  accountDeletionRequest AccountDeletionRequest?
  publicLinkRedirects    PublicLinkRedirect[]

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model AccountEmailChange {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  newEmail  String   @map("new_email")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("account_email_changes")
}

model UserBackupCode {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  codeHash  String   @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, codeHash])
  @@index([userId])
  @@map("user_backup_codes")
}

model NotificationPreference {
  userId        String              @map("user_id")
  channel       NotificationChannel
  type          NotificationType
  enabled       Boolean             @default(true)
  timingMinutes Int?                @map("timing_minutes")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, channel, type])
  @@map("notification_preferences")
}

model UserSession {
  id                          String   @id @default(uuid())
  userId                      String   @map("user_id")
  refreshTokenHash            String   @map("refresh_token_hash")
  // The most-recently rotated-out refresh hash. If a client ever presents this
  // value again it means somebody held on to a stale token — almost certainly
  // a stolen-cookie replay. We revoke the session on detection.
  previousRefreshTokenHash    String?  @map("previous_refresh_token_hash")
  // Hard ceiling on the session, set at creation. Sliding `expiresAt` can be
  // pushed by refresh but never beyond this. Stops a single sign-in from
  // becoming a perpetual session via constant refresh.
  absoluteExpiresAt           DateTime @map("absolute_expires_at")
  userAgent                   String?  @map("user_agent")
  ipAddress        String?  @map("ip_address")
  ipRegion         String?  @map("ip_region")
  expiresAt        DateTime @map("expires_at")
  // Whether the original sign-in opted into "Keep me signed in". When false we
  // hand out short-lived (12h) sliding sessions and session-scope cookies.
  rememberMe       Boolean  @default(true) @map("remember_me")
  isActive         Boolean  @default(true) @map("is_active")
  lastUsedAt       DateTime @default(now()) @map("last_used_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@index([previousRefreshTokenHash])
  @@map("user_sessions")
}

model EventType {
  id                  String       @id @default(uuid())
  userId              String       @map("user_id")
  slug                String
  title               String
  category            String?
  imageUrl            String?      @map("image_url")
  description         String?
  whatIncluded        String?      @map("what_included")
  locationDetails     String?      @map("location_details")
  durationMinutes     Int          @map("duration_minutes")
  bufferBeforeMinutes Int          @default(0) @map("buffer_before_minutes")
  bufferAfterMinutes  Int          @default(0) @map("buffer_after_minutes")
  locationType        LocationType @default(VIDEO) @map("location_type")
  priceAmount         Int?         @map("price_amount")      // stored in cents, null = price on request
  priceCurrency       String       @default("USD") @map("price_currency")
  priceType           PriceType    @default(FIXED) @map("price_type")
  priceMaxAmount      Int?         @map("price_max_amount")  // upper bound for RANGE pricing, in cents
  preparationNotes    String?      @map("preparation_notes") // "before the appointment" guidance
  galleryImageUrls    String[]     @default([]) @map("gallery_image_urls")
  isFeatured          Boolean      @default(false) @map("is_featured")
  directLinkOnly      Boolean      @default(false) @map("direct_link_only")
  isActive            Boolean      @default(true) @map("is_active")
  deletedAt           DateTime?    @map("deleted_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings              Booking[]
  reviews               Review[]
  availability          EventTypeAvailability?
  availabilityOverrides AvailabilityOverride[]
  publicLinkRedirects   PublicLinkRedirect[]

  @@unique([userId, slug])
  @@map("event_types")
}

model AvailabilityRule {
  id          String @id @default(uuid())
  userId      String @map("user_id")
  dayOfWeek   Int    @map("day_of_week")  // 0 = Sunday ... 6 = Saturday
  startMinute Int    @map("start_minute") // minutes from midnight, e.g. 540 = 09:00
  endMinute   Int    @map("end_minute")   // e.g. 1020 = 17:00

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("availability_rules")
}

model EventTypeAvailability {
  id          String                    @id @default(uuid())
  eventTypeId String                    @unique @map("event_type_id")
  mode        EventTypeAvailabilityMode @default(HOST_DEFAULT)
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")

  eventType EventType                   @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  rules     EventTypeAvailabilityRule[]

  @@map("event_type_availability")
}

model EventTypeAvailabilityRule {
  id             String @id @default(uuid())
  availabilityId String @map("availability_id")
  dayOfWeek      Int    @map("day_of_week")
  startMinute    Int    @map("start_minute")
  endMinute      Int    @map("end_minute")

  availability EventTypeAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)

  @@index([availabilityId])
  @@map("event_type_availability_rules")
}

model AvailabilityOverride {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  eventTypeId String?  @map("event_type_id")
  date        DateTime @db.Date @map("date")
  type        AvailabilityOverrideType @default(BLOCKED) @map("type")
  isBlocked   Boolean  @default(true) @map("is_blocked")
  note        String?
  blocks      Json?    @map("blocks") // [{startMinute, endMinute}] for CUSTOM_HOURS
  groupId     String?  @map("group_id") // shared id for multi-day exception ranges
  createdAt   DateTime @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType EventType? @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, eventTypeId])
  @@index([groupId])
  @@map("availability_overrides")
}

model AvailabilitySchedule {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  rules AvailabilityScheduleRule[]

  @@unique([userId, name])
  @@index([userId])
  @@map("availability_schedules")
}

model AvailabilityScheduleRule {
  id          String @id @default(uuid())
  scheduleId  String @map("schedule_id")
  dayOfWeek   Int    @map("day_of_week")
  startMinute Int    @map("start_minute")
  endMinute   Int    @map("end_minute")

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@map("availability_schedule_rules")
}

model PublicLinkRedirect {
  id            String   @id @default(uuid())
  hostUserId    String   @map("host_user_id")
  oldHostSlug   String   @map("old_host_slug")
  oldEventSlug  String?  @map("old_event_slug")
  eventTypeId   String?  @map("event_type_id")
  createdAt     DateTime @default(now()) @map("created_at")

  host      User       @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  eventType EventType? @relation(fields: [eventTypeId], references: [id], onDelete: SetNull)

  @@unique([oldHostSlug, oldEventSlug])
  @@index([hostUserId])
  @@map("public_link_redirects")
}

model Booking {
  id                 String        @id @default(uuid())
  eventTypeId        String        @map("event_type_id")
  hostUserId         String        @map("host_user_id")
  guestName          String        @map("guest_name")
  guestEmail         String        @map("guest_email")
  guestPhone         String?       @map("guest_phone")
  guestNote          String?       @map("guest_note")
  guestTimezone      String        @map("guest_timezone")
  startTimeUtc       DateTime      @map("start_time_utc")
  endTimeUtc         DateTime      @map("end_time_utc")
  status             BookingStatus @default(CONFIRMED)
  cancellationReason String?       @map("cancellation_reason")
  guestCancelToken   String?       @unique @map("guest_cancel_token")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)
  host      User      @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  review    Review?
  reminder  BookingReminder?
  calendarSyncs CalendarEventSync[]

  @@index([hostUserId, startTimeUtc])
  @@index([eventTypeId])
  @@map("bookings")
}

model BookingReminder {
  bookingId String                @id @map("booking_id")
  sendAt    DateTime              @map("send_at")
  status    BookingReminderStatus @default(PENDING)
  sentAt    DateTime?             @map("sent_at")
  lastError String?               @map("last_error")
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status, sendAt])
  @@map("booking_reminders")
}

model DailyAgendaDelivery {
  userId     String            @map("user_id")
  agendaDate DateTime          @db.Date @map("agenda_date")
  status     DailyAgendaStatus @default(PROCESSING)
  sentAt     DateTime?         @map("sent_at")
  lastError  String?           @map("last_error")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, agendaDate])
  @@index([status, agendaDate])
  @@map("daily_agenda_deliveries")
}

model ConnectedCalendar {
  id                    String                 @id @default(uuid())
  userId                String                 @map("user_id")
  provider              CalendarProvider
  accountEmail          String                 @map("account_email")
  accessTokenEncrypted  String                 @map("access_token_encrypted")
  refreshTokenEncrypted String?                @map("refresh_token_encrypted")
  accessTokenExpiresAt  DateTime?              @map("access_token_expires_at")
  scopes                String[]               @default([])
  conflictsOn           Boolean                @default(true) @map("conflicts_on")
  writeBackCalendarId   String?                @map("write_back_calendar_id")
  markBufferBusy        Boolean                @default(true) @map("mark_buffer_busy")
  includeGuestDetails   Boolean                @default(true) @map("include_guest_details")
  state                 ConnectedCalendarState @default(ACTIVE)
  lastSyncedAt          DateTime?              @map("last_synced_at")
  lastSyncError         String?                @map("last_sync_error")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  conflictCalendars ConflictCalendar[]
  eventSyncs        CalendarEventSync[]

  @@unique([userId, provider, accountEmail])
  @@index([userId, provider])
  @@map("connected_calendars")
}

model ConflictCalendar {
  id                  String   @id @default(uuid())
  connectedCalendarId String   @map("connected_calendar_id")
  providerCalendarId  String   @map("provider_calendar_id")
  name                String
  color               String?
  enabled             Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  connectedCalendar ConnectedCalendar @relation(fields: [connectedCalendarId], references: [id], onDelete: Cascade)

  @@unique([connectedCalendarId, providerCalendarId])
  @@map("conflict_calendars")
}

model CalendarEventSync {
  id                  String                  @id @default(uuid())
  bookingId           String                  @map("booking_id")
  connectedCalendarId String                  @map("connected_calendar_id")
  providerEventId     String?                 @map("provider_event_id")
  providerCalendarId  String?                 @map("provider_calendar_id")
  syncStatus          CalendarEventSyncStatus @default(PENDING) @map("sync_status")
  lastError           String?                 @map("last_error")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")

  booking           Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  connectedCalendar ConnectedCalendar @relation(fields: [connectedCalendarId], references: [id], onDelete: Cascade)

  @@unique([bookingId, connectedCalendarId])
  @@index([connectedCalendarId])
  @@map("calendar_event_syncs")
}

model BookingFeed {
  userId         String   @id @map("user_id")
  tokenHash      String   @unique @map("token_hash")
  tokenEncrypted String   @map("token_encrypted")
  createdAt      DateTime @default(now()) @map("created_at")
  rotatedAt      DateTime? @map("rotated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("booking_feeds")
}

model AccountDeletionRequest {
  userId      String   @id @map("user_id")
  tokenHash   String   @unique @map("token_hash")
  expiresAt   DateTime @map("expires_at")
  confirmedAt DateTime? @map("confirmed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("account_deletion_requests")
}

model OtpVerification {
  id          String   @id @default(uuid())
  email       String
  codeHash    String   @map("code_hash")
  expiresAt   DateTime @map("expires_at")
  attempts    Int      @default(0)
  maxAttempts Int      @default(5) @map("max_attempts")
  isVerified  Boolean  @default(false) @map("is_verified")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("otp_verifications")
}

model Review {
  id              String   @id @default(uuid())
  bookingId       String   @unique @map("booking_id")
  hostUserId      String   @map("host_user_id")
  eventTypeId     String   @map("event_type_id")
  guestName       String   @map("guest_name")
  guestEmail      String   @map("guest_email")
  rating          Int
  comment         String
  isVisible       Boolean  @default(true) @map("is_visible")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  host      User      @relation(fields: [hostUserId], references: [id], onDelete: Cascade)
  eventType EventType @relation(fields: [eventTypeId], references: [id], onDelete: Cascade)

  @@index([hostUserId, isVisible])
  @@index([eventTypeId, isVisible])
  @@map("reviews")
}
