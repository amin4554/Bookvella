# Database
DATABASE_URL="postgresql://bookvella:bookvella_dev@localhost:5433/bookvella?schema=public"

# Server
PORT=3000
CORS_ORIGINS="http://localhost:3001"
APP_URL="http://localhost:3001"

# Auth
# Production must use stable RSA keys. Use escaped newlines when storing in env vars.
JWT_KEY_ID="bookvella-prod-key-1"
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
GOOGLE_CLIENT_ID=
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false

# Booking-code hashing
EMAIL_CODE_SECRET="replace-with-a-long-random-secret"
REVIEW_TOKEN_SECRET="replace-with-a-second-long-random-secret"

# Email
# Leave SMTP_HOST empty in local development to log emails to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Bookvella <no-reply@bookvella.com>"
SMTP_HELO_NAME="bookvella.com"

# Local development helper only
EMAIL_DEV_RETURN_CODE=false
